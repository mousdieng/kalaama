{
  "manifest_version": 3,
  "name": "Kalaama - Learn Languages Anywhere",
  "version": "1.1.0",
  "description": "Learn any language while watching YouTube videos, reading web pages, or PDFs. Interactive subtitles, word translations, grammar highlighting, and vocabulary building.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>",
    "file:///*",
    "https://*.supabase.co/*",
    "https://api.mymemory.translated.net/*",
    "https://libretranslate.com/*",
    "https://translate.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_title": "Kalaama - Click to open captions panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content/content-script.js"],
      "css": ["content/content-styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>", "file:///*"],
      "exclude_matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content/reading-content-script.js"],
      "css": ["content/reading-styles.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "content/page-injector.js",
        "icons/*"
      ],
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"]
    },
    {
      "resources": [
        "content/reading-styles.css",
        "libs/pdf.min.js",
        "libs/pdf.worker.min.js",
        "icons/*"
      ],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "side_panel": {
    "default_path": "app/index.html"
  }
}
