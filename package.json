{
  "name": "kalaama",
  "version": "1.0.0",
  "description": "Learn languages while watching YouTube - Chrome Extension",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run build:angular && npm run build:chrome && npm run copy:assets",
    "build:angular": "ng build",
    "build:chrome": "npm run build:content && npm run build:reading && npm run build:background",
    "build:content": "esbuild src/chrome/content/content-script.ts --bundle --outfile=dist/content/content-script.js --format=iife --target=chrome100",
    "build:reading": "esbuild src/chrome/content/reading-content-script.ts --bundle --outfile=dist/content/reading-content-script.js --format=iife --target=chrome100",
    "build:background": "node scripts/build-service-worker.cjs",
    "watch:content": "esbuild src/chrome/content/content-script.ts --bundle --outfile=dist/content/content-script.js --format=iife --target=chrome100 --watch",
    "watch:background": "esbuild src/chrome/background/service-worker.ts --bundle --outfile=dist/background/service-worker.js --format=esm --target=chrome100 --watch",
    "copy:assets": "node scripts/copy-assets.cjs",
    "import:vocabulary": "node scripts/import-vocabulary.cjs",
    "test": "ng test"
  },
  "keywords": [
    "language-learning",
    "chrome-extension",
    "youtube",
    "subtitles",
    "angular",
    "supabase"
  ],
  "author": "Kalaama Team",
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "@supabase/supabase-js": "^2.43.0",
    "pdfjs-dist": "^3.11.174",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/chrome": "^0.0.268",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.27.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.4.0"
  }
}
